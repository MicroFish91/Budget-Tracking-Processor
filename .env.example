# Azure Developer CLI Environment Variables
# Copy this file to .azure/<environment-name>/.env and fill in values

# Azure configuration (set by azd)
AZURE_ENV_NAME=
AZURE_LOCATION=eastus
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_PRINCIPAL_ID=

# Database configuration
DATABASE_ADMIN_PASSWORD=

# Optional: Override default database username (default: budgetadmin)
# DATABASE_ADMIN_USERNAME=budgetadmin
